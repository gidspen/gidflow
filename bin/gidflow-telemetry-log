#!/bin/bash
# Post a skill event to the gidflow telemetry endpoint.
# Usage: gidflow-telemetry-log --skill NAME --outcome success|error|abort --duration 42 --version 1.0.0
#
# Telemetry is ON by default. Users opt out with:
#   ~/.claude/skills/gidflow/bin/gidflow-config set telemetry off

_GIDFLOW_HOME="${GIDFLOW_HOME:-$HOME/.gidflow}"
_GIDFLOW_DIR="${GIDFLOW_DIR:-$HOME/.claude/skills/gidflow}"

# ── Check telemetry setting ───────────────────────────────────────────────────
_TEL=$("$_GIDFLOW_DIR/bin/gidflow-config" get telemetry 2>/dev/null)
[ "$_TEL" = "off" ] && exit 0

# ── Telemetry endpoint (Edge Function — no secret required) ──────────────────
_ENDPOINT="https://gggmmjvwbbfvrtjjlqvr.supabase.co/functions/v1/gidflow-telemetry"

# ── Parse args ────────────────────────────────────────────────────────────────
SKILL="" OUTCOME="unknown" DURATION=0 VERSION="unknown"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --skill)    SKILL="$2";    shift 2 ;;
    --outcome)  OUTCOME="$2";  shift 2 ;;
    --duration) DURATION="$2"; shift 2 ;;
    --version)  VERSION="$2";  shift 2 ;;
    *) shift ;;
  esac
done

# ── Device hash (anonymous stable identifier) ────────────────────────────────
_DEVICE_FILE="$_GIDFLOW_HOME/.device-id"
if [ ! -f "$_DEVICE_FILE" ]; then
  (uuidgen 2>/dev/null || cat /proc/sys/kernel/random/uuid 2>/dev/null || date +%s%N) > "$_DEVICE_FILE"
fi
_DEVICE_RAW=$(cat "$_DEVICE_FILE")
_DEVICE_HASH=$(printf '%s' "$_DEVICE_RAW" | md5 2>/dev/null || printf '%s' "$_DEVICE_RAW" | md5sum 2>/dev/null | cut -c1-32)

# ── Optional user label (set with: gidflow-config set user_id YOUR_NAME) ─────
_USER_ID=$("$_GIDFLOW_DIR/bin/gidflow-config" get user_id 2>/dev/null || echo "")

# ── POST ──────────────────────────────────────────────────────────────────────
_TS=$(date -u +%Y-%m-%dT%H:%M:%SZ)
_PAYLOAD=$(printf '{"skill":"%s","version":"%s","outcome":"%s","duration_s":%s,"ts":"%s","device_hash":"%s","user_id":"%s"}' \
  "$SKILL" "$VERSION" "$OUTCOME" "$DURATION" "$_TS" "$_DEVICE_HASH" "$_USER_ID")

curl -sS --max-time 5 -X POST \
  "$_ENDPOINT" \
  -H "Content-Type: application/json" \
  -d "$_PAYLOAD" > /dev/null 2>&1 || true
